/**
 * Edge Function: ai-seo-aeo-geo-audit (section 9.2 / 14.4)
 *
 * POST body: { article_id: string }
 *
 * Runs an independent audit call (never combined with draft_generation).
 * Writes one article_scores row per dimension (section 5's 12 dimensions).
 * Human review required before scores are used to gate publication.
 */
// deno-lint-ignore-file no-explicit-any
import "jsr:@supabase/functions-js/edge-runtime.d.ts";
import { createClient } from "jsr:@supabase/supabase-js@2";

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
};

function json(body: unknown, status = 200) {
  return new Response(JSON.stringify(body), {
    status,
    headers: { ...corsHeaders, "Content-Type": "application/json" },
  });
}

const SCORE_DIMENSIONS = [
  "editorial_quality",
  "factual_confidence",
  "search_intent_alignment",
  "seo_readiness",
  "aeo_readiness",
  "geo_readiness",
  "accessibility",
  "readability",
  "internal_linking",
  "source_quality",
  "freshness",
  "conversion_readiness",
] as const;

async function callProvider(provider: any, systemPrompt: string, userPrompt: string) {
  const base = (provider.endpoint_url ?? "").replace(/\/$/, "");
  const apiKey: string = Deno.env.get(provider.api_key_secret_ref) ?? "";

  if (!apiKey) throw new Error(`Secret "${provider.api_key_secret_ref}" not set`);

  if (provider.adapter_type === "anthropic") {
    const url = base || "https://api.anthropic.com";
    const res = await fetch(`${url}/v1/messages`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": apiKey,
        "anthropic-version": "2023-06-01",
      },
      body: JSON.stringify({
        model: provider.default_model,
        max_tokens: 3000,
        temperature: 0.2,
        system: systemPrompt,
        messages: [{ role: "user", content: userPrompt }],
      }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(`Anthropic error ${res.status}: ${JSON.stringify(data)}`);
    return data.content?.filter((c: any) => c.type === "text").map((c: any) => c.text).join("") ?? "";
  }

  if (provider.adapter_type === "openai") {
    const url = base || "https://api.openai.com";
    const res = await fetch(`${url}/v1/chat/completions`, {
      method: "POST",
      headers: { "Content-Type": "application/json", Authorization: "Bearer " + apiKey },
      body: JSON.stringify({
        model: provider.default_model,
        max_tokens: 3000,
        temperature: 0.2,
        messages: [
          { role: "system", content: systemPrompt },
          { role: "user", content: userPrompt },
        ],
      }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(`OpenAI error ${res.status}: ${JSON.stringify(data)}`);
    return data.choices?.[0]?.message?.content ?? "";
  }

  const res = await fetch(base, {
    method: "POST",
    headers: { "Content-Type": "application/json", Authorization: "Bearer " + apiKey },
    body: JSON.stringify({ model: provider.default_model, system: systemPrompt, user: userPrompt, max_tokens: 3000 }),
  });
  const data = await res.json();
  if (!res.ok) throw new Error(`Custom adapter error ${res.status}`);
  return data.text ?? data.content ?? "";
}

Deno.serve(async (req) => {
  if (req.method === "OPTIONS") return new Response("ok", { headers: corsHeaders });
  if (req.method !== "POST") return json({ error: "Method not allowed" }, 405);

  if (!req.headers.get("Authorization")) return json({ error: "Missing Authorization header" }, 401);

  const supabase = createClient(
    Deno.env.get("SUPABASE_URL") ?? "",
    Deno.env.get("SUPABASE_SERVICE_ROLE_KEY") ?? ""
  );

  let body: { article_id?: string };
  try {
    body = await req.json();
  } catch {
    return json({ error: "Invalid JSON body" }, 400);
  }

  const { article_id } = body;
  if (!article_id) return json({ error: "article_id is required" }, 400);

  const { data: article, error: articleErr } = await supabase
    .from("articles")
    .select("id, working_title, title, locale, content, primary_keyword, search_intent, excerpt, pillars(name_en, name_fr)")
    .eq("id", article_id)
    .single();

  if (articleErr || !article) {
    return json({ error: "Article not found", detail: articleErr?.message }, 404);
  }

  const { data: providers } = await supabase
    .from("ai_providers")
    .select("*")
    .eq("is_active", true)
    .contains("assigned_tasks", ["seo_aeo_geo_audit"]);

  const provider = providers?.[0];
  if (!provider) {
    return json({ error: "No active AI provider assigned to seo_aeo_geo_audit." }, 503);
  }

  const pillarName = article.locale === "fr"
    ? article.pillars?.name_fr
    : article.pillars?.name_en;

  // Extract plain text summary from content for the prompt
  const bodyBlocks = (article.content?.sequence ?? []).find((b: any) => b.type === "body_blocks");
  const textSummary = (bodyBlocks?.blocks ?? [])
    .filter((b: any) => b.type === "paragraph" || b.type === "h2" || b.type === "h3")
    .slice(0, 20)
    .map((b: any) => b.type === "paragraph" ? b.spans?.map((s: any) => s.text).join("") : b.text)
    .join("\n")
    .slice(0, 3000);

  const systemPrompt = `You are an SEO, AEO (Answer Engine Optimization), and GEO (Generative Engine Optimization) auditor for Forge-Blog. You audit articles against section-4 and section-5 of the Forge-Blog system prompt. You return only a valid JSON object. Be precise and honest. Do not fabricate scores. Mark factual gaps [à vérifier].`;

  const userPrompt = `Audit this article across all 12 dimensions.

Title: ${article.title ?? article.working_title}
Locale: ${article.locale}
Pillar: ${pillarName ?? "unknown"}
Primary keyword: ${article.primary_keyword ?? "(not set)"}
Search intent: ${article.search_intent ?? "(not set)"}
Excerpt: ${article.excerpt ?? "(none)"}
Content sample:
${textSummary}

Score each dimension 0–100. Return ONLY this JSON shape:
{
  "dimensions": [
    {
      "dimension": "editorial_quality",
      "score": 0,
      "reasoning": "...",
      "top_fixes": ["fix 1", "fix 2"]
    },
    ... one entry per dimension for all 12: ${SCORE_DIMENSIONS.join(", ")}
  ]
}

Severity guidance:
- 80–100: Good, no blocking issues.
- 60–79: Needs improvement, document specific fixes.
- 0–59: Blocking issue — surface exact location and required fix.`;

  let auditText: string;
  try {
    auditText = await callProvider(provider, systemPrompt, userPrompt);
  } catch (err: any) {
    return json({ error: "AI provider call failed", detail: err.message }, 502);
  }

  let auditJson: { dimensions: { dimension: string; score: number; reasoning: string; top_fixes: string[] }[] };
  try {
    const cleaned = auditText.replace(/```json\n?/g, "").replace(/```\n?/g, "").trim();
    auditJson = JSON.parse(cleaned);
  } catch {
    return json({ error: "Model returned invalid JSON", raw: auditText.slice(0, 500) }, 422);
  }

  const auditRunId = crypto.randomUUID();
  const now = new Date().toISOString();

  const rows = (auditJson.dimensions ?? [])
    .filter((d) => SCORE_DIMENSIONS.includes(d.dimension as any))
    .map((d) => ({
      article_id,
      dimension: d.dimension,
      score: Math.min(100, Math.max(0, Math.round(d.score))),
      reasoning: d.reasoning ?? "",
      top_fixes: d.top_fixes ?? [],
      computed_at: now,
      audit_run_id: auditRunId,
    }));

  if (rows.length === 0) {
    return json({ error: "No valid score dimensions found in model response" }, 422);
  }

  const { error: insertErr } = await supabase
    .from("article_scores")
    .insert(rows);

  if (insertErr) {
    return json({ error: "Failed to save scores", detail: insertErr.message }, 500);
  }

  return json({
    ok: true,
    article_id,
    task: "seo_aeo_geo_audit",
    audit_run_id: auditRunId,
    dimensions_scored: rows.length,
    human_approval_required: true,
    scores: rows.map((r) => ({ dimension: r.dimension, score: r.score })),
  });
});
