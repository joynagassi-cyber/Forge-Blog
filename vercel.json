{
  "buildCommand": "pnpm build",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . || true",
  "installCommand": "pnpm install --frozen-lockfile || pnpm install",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/((?!_next|api|auth|favicon|manifest).*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "0"
        }
      ]
    }
  ]
}
